# ===========================================
# 智慧植保指挥平台 - 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local 或 .env.production
# 根据实际环境修改配置值
# 注意：不要将包含敏感信息的 .env 文件提交到版本控制

# -------------------------------------------
# 应用基础配置
# -------------------------------------------

# 应用标题（显示在浏览器标签页）
VITE_APP_TITLE=智慧植保指挥平台

# 应用描述
VITE_APP_DESCRIPTION=智慧农业植保管理平台

# -------------------------------------------
# API 接口配置
# -------------------------------------------

# API 基础地址（开发环境）
VITE_API_BASE_URL=http://localhost:8080/api

# API 超时时间（毫秒）
VITE_API_TIMEOUT=30000

# 是否启用请求重试
VITE_API_RETRY_ENABLED=true

# 请求重试次数
VITE_API_RETRY_COUNT=3

# -------------------------------------------
# 开发环境配置
# -------------------------------------------

# 开发服务器端口
VITE_DEV_PORT=5170

# 是否自动打开浏览器
VITE_OPEN_BROWSER=true

# 是否启用 HTTPS（开发环境）
VITE_HTTPS=false

# API 代理目标地址（开发环境使用）
VITE_PROXY_TARGET=http://localhost:8080

# -------------------------------------------
# 功能开关配置
# -------------------------------------------

# 是否启用调试模式
VITE_DEBUG_MODE=false

# 是否启用性能监控
VITE_PERFORMANCE_MONITORING=false

# 是否启用错误上报
VITE_ERROR_REPORTING=true

# 错误上报地址
VITE_ERROR_REPORT_URL=

# 是否启用 Mock 数据（开发环境）
VITE_MOCK_ENABLED=true

# Mock 数据地址
VITE_MOCK_URL=/db.json

# -------------------------------------------
# UI 配置
# -------------------------------------------

# 默认主题模式 (light/dark/system)
VITE_DEFAULT_THEME=light

# 默认语言 (zh-CN/en-US)
VITE_DEFAULT_LOCALE=zh-CN

# 是否启用动画效果
VITE_ANIMATION_ENABLED=true

# 分页默认大小
VITE_PAGE_SIZE=20

# -------------------------------------------
# 第三方服务配置
# -------------------------------------------

# 地图服务密钥（如高德、百度地图）
VITE_MAP_KEY=

# WebSocket 地址（实时数据推送）
VITE_WS_URL=ws://localhost:8080/ws

# 文件上传大小限制（MB）
VITE_UPLOAD_MAX_SIZE=10

# -------------------------------------------
# 日志配置
# -------------------------------------------

# 日志级别 (debug/info/warn/error)
VITE_LOG_LEVEL=info

# 是否在控制台输出日志
VITE_CONSOLE_LOG=true

# -------------------------------------------
# 生产环境特定配置
# -------------------------------------------

# 生产环境 API 地址
# VITE_API_BASE_URL=https://api.plant-protection.com

# CDN 基础地址（静态资源）
# VITE_CDN_BASE_URL=https://cdn.plant-protection.com

# Google Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX

# 百度统计 ID
# VITE_BAIDU_TONGJI_ID=

# ===========================================
# 使用说明：
#
# 1. 复制此文件：
#    cp .env.example .env.local
#
# 2. 开发环境修改 .env.local
#
# 3. 生产环境创建 .env.production：
#    cp .env.example .env.production
#    # 然后修改生产环境特定的配置
#
# 4. 所有以 VITE_ 开头的变量会在构建时
#    注入到客户端代码中，请勿包含敏感信息
#
# 5. 敏感信息（密钥、密码等）应通过后端
#    环境变量或安全配置中心管理
# ===========================================
