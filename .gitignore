# ===========================================
# Git 忽略规则 - 智慧植保指挥平台
# ===========================================

# -------------------------------------------
# 依赖目录
# -------------------------------------------
node_modules/
.pnp
.pnp.js

# -------------------------------------------
# 构建输出
# -------------------------------------------
dist/
dist-ssr/
*.local

# -------------------------------------------
# 环境变量文件（包含敏感信息）
# -------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -------------------------------------------
# 编辑器与 IDE 配置
# -------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# -------------------------------------------
# 日志文件
# -------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------
# 测试覆盖率报告
# -------------------------------------------
coverage/
*.lcov
.nyc_output/

# -------------------------------------------
# 缓存文件
# -------------------------------------------
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -------------------------------------------
# 临时文件
# -------------------------------------------
*.tmp
*.temp
*.swp
*~
~$*

# -------------------------------------------
# 操作系统文件
# -------------------------------------------
.DS_Store
Desktop.ini
ehthumbs.db

# -------------------------------------------
# 包管理器
# -------------------------------------------
.yarn/install-state.gz
.pnp.*

# -------------------------------------------
# TypeScript
# -------------------------------------------
*.tsbuildinfo

# -------------------------------------------
# 测试相关
# -------------------------------------------
test-results/
playwright-report/
playwright/.cache/

# -------------------------------------------
# 文档生成
# -------------------------------------------
docs/_site/

# -------------------------------------------
# 其他
# -------------------------------------------
.vercel
.netlify
.serverless/
.fusebox/

# -------------------------------------------
# 本地开发特有
# -------------------------------------------
local.config.js
local.config.ts
dev.config.js
dev.config.ts

# -------------------------------------------
# 备份文件
# -------------------------------------------
*.bak
*.backup
*.orig

# -------------------------------------------
# 密钥和证书（绝对不能提交）
# -------------------------------------------
*.pem
*.key
*.crt
*.p12
secrets/
credentials/
